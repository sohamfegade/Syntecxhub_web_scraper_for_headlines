# ==============================================================
# NewsScrape Pro — Environment Variables (template)
# ==============================================================
# Copy this file to  .env  in the project root and fill in any
# values you want to override.  The .env file is git-ignored.
# ==============================================================

# Optional proxy (e.g. http://user:pass@proxy:8080)
HTTP_PROXY=
HTTPS_PROXY=

# Override the database path (absolute or relative to project root)
# DATABASE_PATH=database/newsscrape.db

# Override log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_LEVEL=INFO
